# ─────────────────────────────────────────────────────────────
# tokens.xyz Assets API — Solana tokenized-equity resolution +
# liquidity ranking for /api/stocks, /api/stocks/:ticker, /api/liquidity.
# Get one from https://app.tokens.xyz/  (docs: https://docs.tokens.xyz/)
# When unset, those routes fall back to the bundled data/*.json samples.
# ─────────────────────────────────────────────────────────────
TOKENS_XYZ_API_KEY=

# ─────────────────────────────────────────────────────────────
# Claude API — required for POST /api/analyst and POST /api/predict
# Get one from https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Claude Portfolio (/alpha/portfolio) cron + predict data sources.
# CRON_SECRET   — Vercel Cron auth. Crons send `Authorization: Bearer
#                 <CRON_SECRET>`; the cron routes also accept INTERNAL_API_KEY.
#                 Generate with: openssl rand -hex 32
# SMART_MONEY_URL — Nansen Smart Money screener used by /api/predict (deep).
# BENCHMARK_PROVIDER — SPY/QQQ source for the daily performance cron.
# ─────────────────────────────────────────────────────────────
CRON_SECRET=
SMART_MONEY_URL=https://smartmoneyscreener.vercel.app/api/screener/smart-money
BENCHMARK_PROVIDER=yahoo

# ─────────────────────────────────────────────────────────────
# Phase 1 — x402 wrapper endpoints + AA external-data integration.
# BIRDEYE_API_KEY    — server-side key for POST /api/wrappers/birdeye-ohlcv.
# PERPLEXITY_API_KEY — server-side key for POST /api/wrappers/perplexity-research.
# AA_EXTERNAL_DATA_URL — AA's /api/latest-external-data; the weekly portfolio
#                 cron fetches it (10s timeout, degrades gracefully) and appends
#                 the result to the Claude selection prompt. Unset → skipped.
# ─────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=
PERPLEXITY_API_KEY=
AA_EXTERNAL_DATA_URL=

# ─────────────────────────────────────────────────────────────
# Internal-auth bypass for x402 (skips payment when caller sends
# `X-Internal-Key: <value>`). Used by AA / your own backend.
# Generate one with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
INTERNAL_API_KEY=

# ─────────────────────────────────────────────────────────────
# x402 v2 — receiving wallets per network
# Base mainnet (USDC).      eip155:8453
# Solana mainnet (USDC).    solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# Both default to the addresses hard-coded in lib/x402.ts; override
# here to receive at a different wallet.
# SOLANA_RECEIVE_ADDRESS is the canonical Solana payTo (takes precedence over
# WALLET_ADDRESS_SOLANA); set it to the address that should receive Solana USDC.
# ─────────────────────────────────────────────────────────────
WALLET_ADDRESS_BASE=0xC67d94504696960bA0f2e7C3FeE703950734c00A
WALLET_ADDRESS_SOLANA=4s8XQC2WzRfgH8Xiep7ybnCW11VKRCMwxQF6jknx3VPf
SOLANA_RECEIVE_ADDRESS=

# ─────────────────────────────────────────────────────────────
# Solana x402 facilitator (verify/settle SVM payments).
# The CDP facilitator (CDP_API_KEY_*) verifies Base only. To accept REAL Solana
# USDC payments, point this at a Solana-capable x402 facilitator (e.g. PayAI);
# it is added as a second facilitator client and the SDK routes solana:* verify
# to it. Unset → Solana legs are advertised in discovery but not verifiable
# (Base keeps working unchanged).
# ─────────────────────────────────────────────────────────────
SOLANA_FACILITATOR_URL=

# ─────────────────────────────────────────────────────────────
# Facilitator selection.
# Priority: (1) CDP_API_KEY_ID + CDP_API_KEY_SECRET → @coinbase/x402
#           (2) FACILITATOR_URL → custom HTTP facilitator
#           (3) default → @coinbase/x402 anonymous facilitator
# ─────────────────────────────────────────────────────────────
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
FACILITATOR_URL=
