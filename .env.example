# Claude API key — required for POST /api/analyst
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Shared secret for internal callers (your own backend, AA Anthropic Agent, etc.)
# Generate one with: openssl rand -hex 32
# Callers send `X-Internal-Key: <value>` to bypass x402 charging.
INTERNAL_API_KEY=
